# =============================================================
# Azure Document Intelligence Pipeline — Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically at runtime.
# NEVER commit .env to source control — add it to .gitignore.
# =============================================================

# ---- Required: Azure credentials ----
AZURE_DI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_DI_KEY=your-api-key-here
AZURE_DI_MODEL_ID=your-custom-model-id

# ---- Optional: folder paths (defaults shown) ----
# DOCAI_INPUT_DIR=./input
# DOCAI_INTEL_OUTPUT_DIR=./intel_output
# DOCAI_CLEAN_LABELED_DIR=./clean_labeled_data
# DOCAI_EXCEL_OUTPUT_DIR=./excel_output
# DOCAI_EXCEL_FILENAME=licenses.xlsx
# DOCAI_RUNS_DIR=./runs

# ---- Optional: max file size in MB (default: 500) ----
# DOCAI_MAX_FILE_SIZE_MB=500

# ---- Optional: Stage 1 parallelism (default: 4) ----
# Number of concurrent Azure DI requests. Raise carefully — Azure tiers
# have per-second/per-minute caps and will start returning 429s.
# DOCAI_MAX_WORKERS=4

# ---- Optional: retry attempts on transient Azure errors (default: 3) ----
# DOCAI_MAX_RETRIES=3

# ---- Optional: identifier field for joining array sheets to main rows ----
# Must match the exact label in your custom model.
# DOCAI_ID_FIELD=License Number
